    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst leads = data.data;\n\nlet report = \"📊 Daily Lead Qualification Report\\n\\n\";\n\nlet qualifiedCount = 0;\nlet rejectedCount = 0;\nlet highPriorityCount = 0;\n\nreport += \"✅ Qualified Leads\\n\\n\";\n\nfor (const lead of leads) {\n    if (lead.status === \"Qualified\") {\n        qualifiedCount++;\n\n        if (lead.priority === \"High\") {\n            highPriorityCount++;\n        }\n\n        report += `${lead.name}\\n`;\n        report += `${lead.company}\\n`;\n        report += `Region: ${lead.region}\\n`;\n        report += `Priority: ${lead.priority}\\n\\n`;\n    }\n}\n\nreport += \"--------------------------\\n\\n\";\n\nreport += \"❌ Rejected Leads\\n\\n\";\n\nfor (const lead of leads) {\n    if (lead.status === \"Rejected\") {\n\n        rejectedCount++;\n\n        report += `${lead.name}\\n`;\n        report += `Reason: ${lead.reason}\\n\\n`;\n    }\n}\n\nreport += \"==========================\\n\\n\";\n\nreport += `Qualified : ${qualifiedCount}\\n`;\nreport += `Rejected  : ${rejectedCount}\\n`;\nreport += `High Priority : ${highPriorityCount}`;\n\nreturn [\n    {\n        json: {\n            report\n        }\n    }\n];"
      },
