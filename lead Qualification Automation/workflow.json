    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const lead = $json;\n\n// ---------- Clean Inputs ----------\nconst name = (lead.name || \"\").trim();\nconst email = (lead.email || \"\").trim();\nconst company = (lead.company || \"\").trim();\n\n// ---------- Validation ----------\nconst validName = name !== \"\";\n\nconst validCompany = company !== \"\";\n\nfunction isValidEmail(email) {\n\n    email = (email || \"\").trim();\n\n    const parts = email.split(\"@\");\n\n    return (\n        parts.length === 2 &&\n        parts[0] !== \"\" &&\n        parts[1] !== \"\" &&\n        parts[1].includes(\".\") &&\n        !parts[1].startsWith(\".\") &&\n        !parts[1].endsWith(\".\")\n    );\n}\nconst validEmail = isValidEmail(lead.email);\n// ---------- Overall Status ----------\nconst isValidLead =\n    validName &&\n    validCompany &&\n    validEmail;\n\n// ---------- Reason ----------\nlet reason = null;\n\nif (!validName) {\n    reason = \"Missing name\";\n}\nelse if (!validCompany) {\n    reason = \"Missing company\";\n}\nelse if (!validEmail) {\n    reason = \"Invalid email\";\n}\n\n// ---------- Status ----------\nconst status = isValidLead ? \"Pending\" : \"Rejected\";\n\n// ---------- Return ----------\nreturn {\n    json: {\n        ...lead,\n\n        validation: {\n            name: validName,\n            company: validCompany,\n            email: validEmail\n        },\n\n        isValidLead,\n        status,\n        reason\n    }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
