    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const lead = $json;\n\nlet region = \"Other\";\n\nswitch (lead.country) {\n    case \"USA\":\n    case \"Canada\":\n    case \"Mexico\":\n        region = \"North America\";\n        break;\n\n    case \"Germany\":\n        region = \"Europe\";\n        break;\n\n    case \"India\":\n    case \"Singapore\":\n    case \"Australia\":\n    case \"South Korea\":\n        region = \"APAC\";\n        break;\n}\n\nlet priority = \"Low\";\n\nswitch (region) {\n    case \"North America\":\n        priority = \"High\";\n        break;\n\n    case \"Europe\":\n    case \"APAC\":\n        priority = \"Medium\";\n        break;\n}\n\nreturn {\n    json: {\n        ...lead,\n        region,\n        priority,\n        status: \"Qualified\"\n    }\n};"
      },
